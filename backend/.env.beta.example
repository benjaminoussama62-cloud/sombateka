# SombaTeka — Phase 1 BETA (test APK mondial)
# Copier vers .env.production sur le VPS et adapter.
# Guide complet : BETA_PHASE1.md

ENVIRONMENT=production
# Remplacer par votre URL reelle (sslip.io, domaine, ou Cloudflare Tunnel)
PUBLIC_BASE_URL=https://VOTRE-IP-sslip.io

DB_PASSWORD=GENERE_PAR_setup-beta-secrets.ps1
DATABASE_URL=postgresql+psycopg://sombateka:GENERE_PAR_setup-beta-secrets.ps1@db:5432/sombateka_prod

JWT_SECRET=GENERE_PAR_setup-beta-secrets.ps1
JWT_ISSUER=sombateka-beta
JWT_AUDIENCE=sombateka-mobile-beta
ACCESS_TOKEN_MINUTES=1440

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
USE_REDIS_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=120

# --- Mode beta ferme (retirer avant Play Store public) ---
# OTP visible dans la reponse API si SMS pas encore configure
EXPOSE_OTP_IN_RESPONSE=true
PAYMENT_SANDBOX_MODE=true
ALLOW_DEV_PASSWORD_LOGIN=false

ADMIN_PANEL_PASSWORD=GENERE_PAR_setup-beta-secrets.ps1
ADMIN_SESSION_MINUTES=480

CORS_ORIGINS=*

# SMS — Africa's Talking (voir backend/docs/SMS_SETUP.md)
# Sandbox AT : username=sandbox, cle API depuis le dashboard
SMS_PROVIDER=africas_talking
SMS_API_KEY=
SMS_USERNAME=sandbox
SMS_SENDER_ID=SombaTeka

# Email SMTP (Brevo : smtp-relay.brevo.com:587)
EMAIL_PROVIDER=smtp
EMAIL_FROM=SombaTeka <VOTRE_EMAIL>
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=VOTRE_EMAIL
SMTP_PASSWORD=CLE_SMTP_BREVO_OU_GMAIL
SMTP_USE_TLS=true
SMTP_USE_SSL=false
RESEND_API_KEY=
ADMIN_ALERT_EMAILS=VOTRE_EMAIL

PLATFORM_COMMISSION_PERCENT=5.0
PAYOUT_DELAY_HOURS=24
ESCROW_DELIVERY_HOURS=48

LOG_LEVEL=INFO
SENTRY_DSN=
