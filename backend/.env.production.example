# SombaTeka — Variables d'environnement PRODUCTION
# Copier vers .env.production et remplir TOUTES les valeurs marquées REQUIRED.
# Ne jamais committer .env.production avec de vrais secrets.

# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
PUBLIC_BASE_URL=https://api.sombateka.cd

# REQUIRED — mot de passe PostgreSQL (utilisé aussi par docker-compose)
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

DATABASE_URL=postgresql+psycopg://sombateka:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/sombateka_prod

# REQUIRED — secret JWT 64+ caractères aléatoires
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ISSUER=sombateka-prod
JWT_AUDIENCE=sombateka-mobile-prod
ACCESS_TOKEN_MINUTES=60

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
USE_REDIS_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60

# ── Sécurité ──────────────────────────────────────────────────────────────────
ALLOW_DEV_PASSWORD_LOGIN=false
DEV_LOGIN_PASSWORD=
EXPOSE_OTP_IN_RESPONSE=false
AUTO_CREATE_TABLES=false
SEED_DEV_DATA=false
PAYMENT_SANDBOX_MODE=false

# REQUIRED — mot de passe panneau admin /admin
ADMIN_PANEL_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_SESSION_MINUTES=120
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10

# REQUIRED — domaines autorisés (app web, admin)
CORS_ORIGINS=https://sombateka.cd,https://www.sombateka.cd,https://api.sombateka.cd

# ── SMS OTP ───────────────────────────────────────────────────────────────────
# REQUIRED en prod : africas_talking | twilio (pas "log")
SMS_PROVIDER=africas_talking
SMS_API_KEY=CHANGE_ME
SMS_USERNAME=CHANGE_ME
SMS_SENDER_ID=SombaTeka

# ── Email ─────────────────────────────────────────────────────────────────────
# smtp | resend
EMAIL_PROVIDER=smtp
EMAIL_FROM=SombaTeka <noreply@sombateka.cd>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_USE_TLS=true
SMTP_USE_SSL=false
RESEND_API_KEY=
ADMIN_ALERT_EMAILS=admin@sombateka.cd,support@sombateka.cd

# ── Mobile Money ──────────────────────────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=5.0
PAYOUT_DELAY_HOURS=24
ESCROW_DELIVERY_HOURS=48
REPORTS_AUTO_HIDE_THRESHOLD=3

MTN_MONEY_API_URL=
MTN_MONEY_API_KEY=
MTN_MONEY_API_SECRET=
MTN_MONEY_SUBSCRIPTION_KEY=
MTN_MONEY_CALLBACK_SECRET=

ORANGE_MONEY_API_URL=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_CALLBACK_SECRET=

# Webhooks à enregistrer chez les opérateurs :
#   https://api.sombateka.cd/api/webhooks/mtn
#   https://api.sombateka.cd/api/webhooks/orange

# ── Stockage images (optionnel — local ./uploads si vide) ─────────────────────
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=sombateka-uploads
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

UPLOAD_MAX_BYTES=6291456

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

LOG_LEVEL=INFO
