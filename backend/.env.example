DATABASE_URL=sqlite:///./sombateka.dev.sqlite
PUBLIC_BASE_URL=http://localhost:8000

ENVIRONMENT=dev
JWT_SECRET=dev-only-change-me-change-in-production

REDIS_URL=redis://localhost:6379/0
USE_REDIS_RATE_LIMIT=true

ALLOW_DEV_PASSWORD_LOGIN=true
DEV_LOGIN_PASSWORD=dev
ADMIN_PANEL_PASSWORD=
ADMIN_SESSION_MINUTES=480
EXPOSE_OTP_IN_RESPONSE=true
PAYMENT_SANDBOX_MODE=true
SEED_DEV_DATA=true
AUTO_CREATE_TABLES=true

SMS_PROVIDER=log
SMS_API_KEY=
SMS_USERNAME=
SMS_SENDER_ID=SombaTeka

PLATFORM_COMMISSION_PERCENT=5.0
PAYOUT_DELAY_HOURS=24
ESCROW_DELIVERY_HOURS=48
REPORTS_AUTO_HIDE_THRESHOLD=3

MTN_MONEY_API_URL=
MTN_MONEY_API_KEY=
MTN_MONEY_API_SECRET=
MTN_MONEY_SUBSCRIPTION_KEY=
MTN_MONEY_CALLBACK_SECRET=

ORANGE_MONEY_API_URL=
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_CALLBACK_SECRET=

# Laisser vide en dev : le backend autorise automatiquement localhost + IP LAN (192.168.x.x).
# Pour la prod, lister les domaines exacts :
# CORS_ORIGINS=https://votredomaine.com

S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=sombateka-uploads
S3_PUBLIC_BASE_URL=

# Email (log = console en dev, smtp ou resend en prod)
EMAIL_PROVIDER=log
EMAIL_FROM=SombaTeka <noreply@sombateka.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
RESEND_API_KEY=
# Alertes admin (KYC, signalements) — séparées par des virgules
ADMIN_ALERT_EMAILS=

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
